---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ScrollTop from '../components/ScrollTop.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Banner from '../components/Banner.astro';
import BannerDataInjector from '../components/BannerDataInjector.astro';
import FAQ from '../components/FAQ.astro';
import Disclaimer from '../components/Disclaimer.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

// Single global CSS entry
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	metaOgTitle?: string; // OG заголовок для соцсетей (опционально)
	readingTime?: number; // Время чтения в минутах (вычисляется автоматически)
	pubDate?: Date | string;
	updatedDate?: Date | string;
	heroImage?: string;
	bannerImage?: string;
	category?: string;
	tags?: string[];
	faq?: { q: string; a: string }[];
	postId?: string;
	headings?: { depth: number; slug: string; text: string }[];
	customBreadcrumbs?: { label: string; href?: string }[];
}

// Helper to convert string to Date (Astro 5 collections return dates as strings)
const toDate = (d: Date | string | undefined): Date | undefined =>
	d ? (typeof d === 'string' ? new Date(d) : d) : undefined;

const { title, description, metaOgTitle, readingTime, pubDate, updatedDate, heroImage, bannerImage, category, tags, faq, postId, headings, customBreadcrumbs } = Astro.props;
const displayImage = heroImage || bannerImage;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const titleWords = title.split(/\s+/).length;
const headingClass = titleWords <= 5 ? 'brutal' : 'long';

// Содержание на разных языках
const tocTitle = {
	ru: 'Содержание',
	en: 'Table of Contents'
}[lang] || 'Содержание';

const breadcrumbItems: Array<{ label: string; href?: string }> = customBreadcrumbs || (() => {
	const items: Array<{ label: string; href?: string }> = [
		{ label: t('nav.library'), href: translatePath('library') }
	];
	
	// Добавляем категорию в хлебные крошки, если она указана
	if (category) {
		const catLabel = t(`cat.${category}` as any);
		if (catLabel) {
			items.push({ label: catLabel, href: `${translatePath('library')}?cat=${category}` });
		}
	}
	
	items.push({ label: title });
	return items;
})();
---

<html lang={lang}>
	<head>
		<BaseHead title={title} description={description} metaOgTitle={metaOgTitle} image={displayImage} />
		
		{/* Schema.org Article */}
		{pubDate && (() => {
			const pubDateObj = toDate(pubDate)!;
			const updatedDateObj = toDate(updatedDate);
			// TS: держим как any, т.к. поле image добавляется условно
			const articleSchema: any = {
				"@context": "https://schema.org",
				"@type": "Article",
				"headline": title,
				"description": description,
				"author": {
					"@type": "Person",
					"name": "Hampfree"
				},
				"datePublished": pubDateObj.toISOString(),
				"dateModified": updatedDateObj ? updatedDateObj.toISOString() : pubDateObj.toISOString(),
				"publisher": {
					"@type": "Organization",
					"name": "MarketLab Academy",
					"url": Astro.site?.href || "https://marketlab-academy.org",
					"logo": {
						"@type": "ImageObject",
						"url": new URL("/favicon-96x96.png", Astro.site || "https://marketlab-academy.org").href
					}
				},
				"mainEntityOfPage": {
					"@type": "WebPage",
					"@id": Astro.url.href
				}
			};
			
			if (displayImage) {
				articleSchema.image = {
					"@type": "ImageObject",
					"url": new URL(displayImage, Astro.site || "https://marketlab-academy.org").href
				};
			}
			
			return (
				<script type="application/ld+json" set:html={JSON.stringify(articleSchema, null, 0)} />
			);
		})()}
		
		{/* Schema.org BreadcrumbList */}
		{breadcrumbItems.length > 0 && (() => {
			const breadcrumbSchema = {
				"@context": "https://schema.org",
				"@type": "BreadcrumbList",
				"itemListElement": breadcrumbItems.map((item, index) => ({
					"@type": "ListItem",
					"position": index + 1,
					"name": item.label,
					"item": item.href 
						? new URL(item.href, Astro.site || "https://marketlab-academy.org").href
						: Astro.url.href
				}))
			};
			
			const breadcrumbJson = JSON.stringify(breadcrumbSchema, null, 0);
			return (
				<script type="application/ld+json" set:html={breadcrumbJson} />
			);
		})()}
	</head>

	<body>
		<Header />
		<main class="container">
			<div class="layout-grid">
				<article class="fade-in" data-category={category || ''}>
					<Breadcrumb items={breadcrumbItems} />
					
					{pubDate && (
						<div class="meta" style="margin-bottom: var(--space-1); display: flex; gap: var(--space-2); align-items: center; flex-wrap: wrap;">
							<FormattedDate date={pubDate} />
							{updatedDate && <span> • UPDATED: <FormattedDate date={updatedDate} /></span>}
							{readingTime && readingTime > 0 && (
								<span> • {readingTime} {lang === 'ru' ? 'мин' : lang === 'en' ? 'min' : 'min'} {lang === 'ru' ? 'чтения' : lang === 'en' ? 'read' : 'lectura'}</span>
							)}
						</div>
					)}

					<Banner 
						title={title} 
						subtitle={description}
						category={category} 
						type="full" 
						className="hero-img"
					/>

					<div class="prose">
						<slot />
					</div>

					{postId && (
						<div class="nes-container with-title related-posts-container">
							<p class="title">{t('home.recent_label') || 'RELATED'}</p>
							<RelatedPosts currentPostId={postId} category={category} />
						</div>
					)}

					<div class="post-disclaimer">
						<Disclaimer />
					</div>
				</article>

				<aside class="toc-sticky">
					<div class="nes-container with-title">
						<p class="title">{tocTitle}</p>
					<ul class="toc-list">
						{headings?.map((heading) => {
							// Отступ слева для оглавления:
							// depth=2: 0, depth=3: 16px (--space-2), depth=4: 24px (--space-3)
							// (раньше depth=2 уже был 32px и выглядел "съехавшим")
							const paddingLeft =
								heading.depth === 2 ? '0' :
								heading.depth === 3 ? 'var(--space-2)' :
								heading.depth === 4 ? 'var(--space-3)' :
								`calc(var(--space-2) * ${Math.max(0, heading.depth - 2)})`;
							return (
								<li class="toc-item" style={`padding-left: ${paddingLeft}`}>
									<a href={`#${heading.slug}`}>{heading.text}</a>
								</li>
							);
						})}
					</ul>
					</div>
				</aside>
			</div>

			<ScrollTop />
		</main>
		<BannerDataInjector />
		<Footer />

		<script is:inline>
			// Track banner clicks (GA4)
			function trackBannerClick(element) {
				if (typeof gtag === 'undefined') return;

				const bannerId = element.dataset.bannerId || 'unknown';
				const bannerName = element.dataset.bannerName || 'Unknown';
				const bannerLink = element.dataset.bannerLink || '';
				const category = document.querySelector('article')?.dataset.category || '';
				const lang = document.querySelector('html')?.lang || 'ru';
				const pathname = window.location.pathname;

				// Send event to GA4
				gtag('event', 'referral_banner_click', {
					event_category: 'referral',
					event_label: bannerName,
					banner_id: bannerId,
					banner_link: bannerLink,
					article_category: category,
					article_lang: lang,
					article_path: pathname,
					transport_type: 'beacon',
				});
				
				// Also track as outbound link
				gtag('event', 'click', {
					event_category: 'outbound',
					event_label: bannerLink,
					transport_type: 'beacon',
				});
			}

			// Interactive TOC Highlighting - оптимизировано для предотвращения дёргания
			const observerOptions = {
				root: null,
				rootMargin: '0px 0px -80% 0px',
				threshold: 0
			};

			let currentActiveLink = null;
			let rafId = null;

			const updateActiveLink = (id) => {
				if (rafId) {
					cancelAnimationFrame(rafId);
				}
				
				rafId = requestAnimationFrame(() => {
					const activeLink = document.querySelector(`.toc-item a[href="#${id}"]`);
					
					// Обновляем только если активная ссылка изменилась
					if (activeLink && activeLink !== currentActiveLink) {
						// Удаляем класс у предыдущей активной ссылки
						if (currentActiveLink) {
							currentActiveLink.classList.remove('active');
						}
						// Добавляем класс к новой активной ссылке
						activeLink.classList.add('active');
						currentActiveLink = activeLink;
					}
					
					rafId = null;
				});
			};

			const observer = new IntersectionObserver((entries) => {
				// Находим первый видимый заголовок (ближайший к верху viewport)
				const visibleHeaders = entries
					.filter(entry => entry.isIntersecting)
					.map(entry => ({
						element: entry.target,
						top: entry.boundingClientRect.top
					}))
					.sort((a, b) => a.top - b.top);

				if (visibleHeaders.length > 0) {
					const id = visibleHeaders[0].element.getAttribute('id');
					if (id) {
						updateActiveLink(id);
					}
				}
			}, observerOptions);

			// Observe all headers inside .prose
			document.querySelectorAll('.prose h2, .prose h3').forEach((header) => {
				observer.observe(header);
			});

			// Add banner styles to head (once)
			if (!document.getElementById('banner-styles')) {
				const styleEl = document.createElement('style');
				styleEl.id = 'banner-styles';
				styleEl.textContent = `
					.in-article-ad-container {
						width: 100%;
						max-width: var(--max-width-post, 800px);
						margin: 2rem auto;
						padding: 0;
						display: block;
						box-sizing: border-box;
					}
					.ad-banner-link {
						display: block;
						background: linear-gradient(135deg, var(--bg-start), var(--bg-end));
						border-radius: 0;
						padding: 20px 24px;
						text-decoration: none !important;
						position: relative;
						overflow: hidden;
						width: 100%;
						max-width: 100%;
						box-sizing: border-box;
						border: 4px solid var(--border-color);
					}
					.ad-banner-link::before {
						content: "";
						position: absolute;
						top: 0;
						left: 0;
						width: 100%;
						height: 100%;
						background: repeating-linear-gradient(
							rgba(0, 0, 0, 0.05),
							rgba(0, 0, 0, 0.05) 1px,
							transparent 1px,
							transparent 4px
						);
						pointer-events: none;
						z-index: 1;
					}
					.ad-banner-content {
						position: relative;
						z-index: 2;
						display: flex;
						flex-direction: row;
						align-items: center;
						justify-content: space-between;
						gap: 16px;
						width: 100%;
					}
					.text-block {
						flex: 1;
						display: flex;
						flex-direction: column;
						gap: 6px;
						overflow: visible;
						min-width: 0;
					}
					.title {
						font-family: 'Press Start 2P', monospace;
						font-size: clamp(12px, 2vw + 10px, 16px);
						color: var(--text-color);
						line-height: 1.4;
						text-transform: uppercase;
						margin: 0;
						white-space: normal;
						overflow: visible;
						text-overflow: clip;
						word-wrap: break-word;
						overflow-wrap: break-word;
					}
					.subtitle {
						font-family: 'JetBrains Mono', monospace;
						font-size: clamp(10px, 1.5vw + 8px, 12px);
						color: var(--text-color);
						opacity: 0.9;
						line-height: 1.5;
						white-space: normal;
						overflow: visible;
						text-overflow: clip;
						margin: 0;
						word-wrap: break-word;
						overflow-wrap: break-word;
					}
					.cta {
						display: inline-flex;
						align-items: center;
						gap: 6px;
						font-family: 'Press Start 2P', monospace;
						font-size: clamp(10px, 1.5vw + 8px, 12px);
						background: var(--cta-bg);
						color: var(--cta-text);
						padding: 8px 16px;
						border: 2px solid #000;
						box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.3);
						text-transform: uppercase;
						white-space: nowrap;
						flex-shrink: 0;
						margin: 0;
					}
					.cta-arrow {
						display: inline-block;
						width: 0;
						height: 0;
						border-top: 5px solid transparent;
						border-bottom: 5px solid transparent;
						border-left: 7px solid currentColor;
						line-height: 0;
						vertical-align: middle;
					}
					@media (max-width: 768px) {
						.in-article-ad-container { margin: 2rem auto; padding: 0; }
						.ad-banner-content {
							flex-direction: column;
							align-items: center;
							text-align: center;
							gap: 12px;
						}
						.text-block { width: 100%; text-align: center; }
						.cta { white-space: nowrap; width: auto; min-width: 200px; max-width: 300px; justify-content: center; }
					}
					@media (max-width: 480px) {
						.in-article-ad-container { padding: 0; }
						.ad-banner-link { padding: 16px 18px; }
						.title { font-size: 11px; }
						.subtitle { font-size: 9px; }
						.cta { padding: 7px 16px; min-width: 180px; }
					}
					@media (max-width: 360px) {
						.in-article-ad-container { padding: 0; }
						.ad-banner-link { padding: 14px 16px; }
						.title { font-size: 10px; }
						.subtitle { font-size: 8px; }
						.cta { font-size: 8px; padding: 6px 14px; min-width: 160px; }
					}
				`;
				document.head.appendChild(styleEl);
			}

			// Insert ad banner after 2nd H2 (responsive HTML/CSS, not PNG)
			document.addEventListener('DOMContentLoaded', function() {
				console.log('[DEBUG] DOMContentLoaded, starting insertAdBanner');

				// Add banner styles to head
				const bannerStyles = `
					.in-article-ad-container { width: 100%; max-width: var(--max-width-post, 800px); margin: 2rem auto; padding: 0; display: block; box-sizing: border-box; }
					.ad-banner-link { display: block; background: linear-gradient(135deg, var(--bg-start), var(--bg-end)); border-radius: 0; padding: 20px 24px; text-decoration: none !important; position: relative; overflow: hidden; width: 100%; max-width: 100%; box-sizing: border-box; }
					.ad-banner-link::before { content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: repeating-linear-gradient(rgba(0, 0, 0, 0.05), rgba(0, 0, 0, 0.05) 1px, transparent 1px, transparent 4px); pointer-events: none; z-index: 1; }
					.ad-banner-link::after { content: ""; position: absolute; top: 6px; left: 6px; right: 6px; bottom: 6px; border: 2px solid var(--border-color); border-radius: 0; pointer-events: none; z-index: 1; }
					.ad-banner-content { position: relative; z-index: 2; display: flex; flex-direction: row; align-items: center; justify-content: space-between; gap: 16px; width: 100%; }
					.text-block { flex: 1; display: flex; flex-direction: column; gap: 6px; overflow: visible; min-width: 0; }
					.title { font-family: 'Press Start 2P', monospace; font-size: clamp(12px, 2vw + 10px, 16px); color: var(--text-color); line-height: 1.4; text-transform: uppercase; white-space: normal; overflow: visible; text-overflow: clip; margin: 0; word-wrap: break-word; overflow-wrap: break-word; }
					.subtitle { font-family: 'JetBrains Mono', monospace; font-size: clamp(10px, 1.5vw + 8px, 12px); color: var(--text-color); opacity: 0.9; line-height: 1.5; white-space: normal; overflow: visible; text-overflow: clip; margin: 0; word-wrap: break-word; overflow-wrap: break-word; }
					.cta { display: inline-flex; align-items: center; gap: 6px; font-family: 'Press Start 2P', monospace; font-size: clamp(10px, 1.5vw + 8px, 12px); background: var(--cta-bg); color: var(--cta-text); padding: 8px 16px; border: 2px solid #000; box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.3); text-transform: uppercase; white-space: nowrap; flex-shrink: 0; margin: 0; }
					.cta-arrow { display: inline-block; width: 0; height: 0; border-top: 5px solid transparent; border-bottom: 5px solid transparent; border-left: 7px solid currentColor; line-height: 0; vertical-align: middle; }
					@media (max-width: 768px) { .in-article-ad-container { margin: 2rem auto; padding: 0; } .ad-banner-content { flex-direction: column; align-items: center; text-align: center; gap: 12px; } .text-block { width: 100%; text-align: center; } .cta { white-space: nowrap; width: auto; min-width: 200px; max-width: 300px; justify-content: center; } }
					@media (max-width: 480px) { .in-article-ad-container { padding: 0; } .ad-banner-link { padding: 16px 18px; } .title { font-size: 11px; } .subtitle { font-size: 9px; } .cta { padding: 7px 16px; min-width: 180px; } }
					@media (max-width: 360px) { .in-article-ad-container { padding: 0; } .ad-banner-link { padding: 14px 16px; } .title { font-size: 10px; } .subtitle { font-size: 8px; } .cta { font-size: 8px; padding: 6px 14px; min-width: 160px; } }
				`;
				const styleEl = document.createElement('style');
				styleEl.textContent = bannerStyles;
				document.head.appendChild(styleEl);

				// Import banner logic from central config
				const category = document.querySelector('article')?.dataset.category || '';
				const lang = document.querySelector('html')?.lang || 'ru';
				const pathname = window.location.pathname;
				const slug = pathname.split('/').filter(Boolean)[2] || 'unknown';
				const h2Index = 1; // After 2nd H2 (0-based index)

				console.log('[DEBUG] category:', category, 'lang:', lang, 'slug:', slug);

				// Banner data from BannerDataInjector (единый источник — ad-banners.ts)
				function getBannerForCategory(category, lang, slug) {
					// Логика выбора баннера по категории и языку с балансом
					let bannerId = 'bybit-general'; // fallback

					if (category === 'algo-trading') {
						// Ginarea-статьи → BitMEX (упоминают BitMEX), Veles → Veles
						const isGinarea = slug.includes('ginarea');
						bannerId = isGinarea ? 'bitmex-algo' : 'veles-algo';
					} else if (category === 'fundamental-analysis' && lang === 'ru') {
						bannerId = 'finbazar-fundamental'; // Только для RU!
					} else if (category === 'fundamental-analysis' && lang === 'en') {
						bannerId = 'bybit-general'; // EN/ES → Bybit
					} else if (category === 'crypto') {
						// Баланс: 50% Bybit, 50% Bitget
						bannerId = (slug.includes('staking') || slug.includes('defi') || slug.includes('token'))
							? 'bitget-general'
							: 'bybit-general';
					} else if (category === 'technical-analysis') {
						// Баланс: 50% BingX, 50% Bitget
						bannerId = (slug.includes('rsi') || slug.includes('macd') || slug.includes('bollinger'))
							? 'bingx-general'
							: 'bitget-general';
					} else {
						// fallback: Bitget → Bybit → BingX
						bannerId = 'bitget-general';
					}

					const banner = BANNER_DATA[bannerId];
					if (!banner) {
						console.error('[BANNER] Banner ID not found:', bannerId);
						return null;
					}
					const link = typeof banner.link === 'string' ? banner.link : (banner.link[lang] || banner.link.ru);

					return {
						id: bannerId,
						title: banner.title[lang] || banner.title.ru,
						subtitle: banner.subtitle[lang] || banner.subtitle.ru,
						cta: banner.cta[lang] || banner.cta.ru,
						link: link,
						colors: banner.colors
					};
				}

				const article = document.querySelector('article .prose');
				if (!article) {
					console.log('[DEBUG] article .prose not found');
					return;
				}

				const h2s = Array.from(article.querySelectorAll('h2'));
				console.log('[DEBUG] H2 count:', h2s.length);
				if (h2s.length <= h2Index) {
					console.log('[DEBUG] Not enough H2 tags');
					return;
				}

				const targetH2 = h2s[h2Index];
				const bannerData = getBannerForCategory(category, lang, slug);
				console.log('[DEBUG] bannerData:', bannerData);
				if (!bannerData) {
					console.log('[DEBUG] No banner data available');
					return;
				}
				
				// Build UTM-tagged link
				const utmParams = `?utm_source=marketlab-blog&utm_medium=referral-banner&utm_campaign=${bannerData.id}&utm_content=${slug}&utm_term=${category}`;
				const finalLink = bannerData.link.includes('?') 
					? `${bannerData.link}&utm_source=marketlab-blog&utm_medium=referral-banner&utm_campaign=${bannerData.id}&utm_content=${slug}&utm_term=${category}`
					: `${bannerData.link}${utmParams}`;

				const bannerContainer = document.createElement('div');
				bannerContainer.className = 'in-article-ad-container';
				bannerContainer.setAttribute('role', 'banner');
				bannerContainer.setAttribute('aria-label', 'Advertisement');

				bannerContainer.innerHTML = `
					<a
						href="${finalLink}"
						target="_blank"
						rel="nofollow sponsored"
						class="ad-banner-link"
						data-banner-id="${bannerData.id}"
						data-banner-name="${bannerData.title.replace(/"/g, '&quot;')}"
						data-banner-link="${finalLink}"
						style="--bg-start:${bannerData.colors.bgStart};--bg-end:${bannerData.colors.bgEnd};--text-color:${bannerData.colors.text};--cta-bg:${bannerData.colors.ctaBg};--cta-text:${bannerData.colors.ctaText};--border-color:${bannerData.colors.border};"
						onclick="trackBannerClick(this)"
					>
						<div class="ad-banner-content">
							<div class="text-block">
								<div class="title">${bannerData.title}</div>
								<div class="subtitle">${bannerData.subtitle}</div>
							</div>
							<div class="cta">
								${bannerData.cta.replace('→', '')}
								<span class="cta-arrow"></span>
							</div>
						</div>
					</a>
				`;

				if (targetH2.parentNode) {
