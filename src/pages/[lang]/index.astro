---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import FormattedDate from '../../components/FormattedDate.astro';
import ScrollTop from '../../components/ScrollTop.astro';
import Banner from '../../components/Banner.astro';
import SubscribeForm from '../../components/SubscribeForm.astro';
import NovelScene from '../../components/NovelScene.astro';
import { ui } from '../../i18n/ui';
import { useTranslations, useTranslatedPath } from '../../i18n/utils';
import { isTempArticle } from '../../utils/blog';

export async function getStaticPaths() {
  return [
    { params: { lang: 'ru' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof ui);
const translatePath = useTranslatedPath(lang as keyof typeof ui);

// Fetch only posts for current language
const collectionName = `blog-${lang}` as 'blog-ru' | 'blog-en';
const posts = await getCollection(collectionName).catch((err) => {
	console.error(`Error loading posts for ${collectionName}:`, err);
	return [];
});

// 🔒 ДЕДУПЛИКАЦИЯ: нормализуем post.id и убираем дубликаты
const normalizePostId = (id: string) => id.replace(/\/index$/, '').replace(/\/+$/, '');
const seenIds = new Set<string>();
const seenTitleCategory = new Set<string>();
const uniquePosts = posts.filter(post => {
	if (isTempArticle(post.id)) return false;
	if (post.data.draft) return false;
	
	const normalizedId = normalizePostId(post.id);
	const titleCategoryKey = `${post.data.title}|${post.data.category || ''}`;
	
	if (seenIds.has(normalizedId) || seenTitleCategory.has(titleCategoryKey)) {
		return false;
	}
	
	seenIds.add(normalizedId);
	seenTitleCategory.has(titleCategoryKey);
	Object.assign(post, { id: normalizedId });
	return true;
});

// ПОСЛЕДНИЕ_СТАТЬИ: pinned первыми, затем по pubDate
const sortedPosts = uniquePosts.sort((a, b) => {
	if (a.data.pinned && !b.data.pinned) return -1;
	if (!a.data.pinned && b.data.pinned) return 1;
	const byDate = b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
	if (byDate !== 0) return byDate;
	return (a.id ?? '').localeCompare(b.id ?? '');
});
const featuredPosts = sortedPosts.slice(0, 4);

const categories = [
	{ id: 'technical-analysis', label: t('cat.technical-analysis'), full: t('cat.technical-analysis.full') },
	{ id: 'crypto', label: t('cat.crypto'), full: t('cat.crypto.full') },
	{ id: 'algo-trading', label: t('cat.algo-trading'), full: t('cat.algo-trading.full') },
	{ id: 'fundamental-analysis', label: t('cat.fundamental-analysis'), full: t('cat.fundamental-analysis.full') }
];
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead 
			title={SITE_TITLE} 
			description={t('home.hero_description')} 
		/>
	</head>
	<body>
		<Header />
		<main class="container">
			<!-- Hero section with background vector -->
			<section class="hero">
				<NovelScene />
				<div class="hero-content">
					<h1>{t('home.hero_title')}</h1>
					<p>{t('home.hero_description')}</p>
					<div class="hero-actions">
						<a href={translatePath('library')} class="btn"><span>{t('home.hero_cta')}</span></a>
					</div>
				</div>
			</section>

			<!-- Latest posts -->
			<section aria-labelledby="latest-label">
				<div id="latest-label" class="section-label">{t('home.latest_label')}</div>
				{featuredPosts.length > 0 ? (
					<div class="posts-grid">
						{featuredPosts.map(post => (
							<a href={translatePath(`library/${post.id}`)} class="post-card" aria-label={`${t('library.read_more')}: ${post.data.title}`}>
								<Banner 
									title={post.data.title} 
									subtitle={post.data.description}
									category={post.data.category} 
									type="preview" 
								/>
								<div class="post-meta-wrap">
									<div class="post-meta">
										<span><FormattedDate date={post.data.pubDate} /></span>
									</div>
								</div>
								<div class="read-more-link" aria-hidden="true">{t('library.read_more')}</div>
							</a>
						))}
					</div>
				) : (
					<div style="padding: var(--space-6); text-align: center; color: var(--color-text-secondary);">
						<p>Статьи не найдены.</p>
					</div>
				)}
			</section>

			<!-- Subscribe — coming soon -->
			<section class="subscribe-section">
				<div class="subscribe-with-container">
					<h2>{t('subscribe.coming_soon')}</h2>
					<p class="newsletter-desc">{t('subscribe.coming_soon_desc')}</p>
				</div>
			</section>

			<ScrollTop />
		</main>
		<Footer />
	</body>
</html>
