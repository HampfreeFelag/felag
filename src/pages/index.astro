---
// Root entrypoint: redirect user to best language.
// Priority:
// 1. Saved language (localStorage)
// 2. Browser languages (navigator.languages)
// 3. Geo-IP detection (via Accept-Language header - server-side, if available)
// 4. Fallback: ru
//
// IMPORTANT: GitHub Pages is static hosting, so Geo-IP is not available.
// We use browser language as proxy for region detection.
const BASE_URL = import.meta.env.BASE_URL?.endsWith('/')
	? import.meta.env.BASE_URL
	: (import.meta.env.BASE_URL || '/') + '/';
---
<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<title>Redirecting…</title>
	<meta name="robots" content="noindex" />
	<link rel="canonical" href={BASE_URL} />
	<!-- No meta refresh - Astro doesn't support dynamic values in meta content -->
	<script is:inline>
		(() => {
			const supported = ['ru', 'en'];

			const safeGetStoredLang = () => {
				try {
					const v = window.localStorage.getItem('ml_lang');
					return v && supported.includes(v) ? v : null;
				} catch {
					return null;
				}
			};

			const detectBrowserLang = () => {
				const rawList = (navigator.languages && navigator.languages.length)
					? navigator.languages
					: [navigator.language || ''];

				for (const raw of rawList) {
					const base = String(raw).toLowerCase().split('-')[0];
					if (supported.includes(base)) return base;
				}
				return null;
			};

			// Detect region from timezone (more reliable than language for region)
			const detectRegionFromTimezone = () => {
				try {
					const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
					if (tz.includes('Moscow') || tz.includes('Europe') || tz.includes('Kirov')) return 'ru';
					if (tz.includes('America') || tz.includes('US') || tz.includes('Canada')) return 'en';
				} catch {
					return null;
				}
				return null;
			};

			const stored = safeGetStoredLang();
			const browser = detectBrowserLang();
			const region = detectRegionFromTimezone();
			
			// Priority: stored > browser > region > fallback
			const detected = stored || browser || region || 'ru';
			const base = '/';

			// Ensure base ends with "/" and redirect to /{lang}/ under that base
			window.location.replace(base + detected + '/');
		})();
	</script>
</head>
<body>
	<!-- Fallback for users without JavaScript -->
	<noscript>
		<div style="font-family: monospace; padding: 2rem; text-align: center;">
			<p>Redirecting...</p>
			<p>If you are not redirected, <a href="/ru/">click here for Russian</a></p>
			<ul style="list-style: none; padding: 0;">
				<li><a href="/ru/">Русский</a></li>
				<li><a href="/en/">English</a></li>
			</ul>
		</div>
	</noscript>
</body>
</html>
