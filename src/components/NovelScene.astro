---
// NovelScene — минималистичный векторный фон для hero-секции
// Тихие геометрические формы, скандинавский минимализм
---

<div class="novel-scene" aria-hidden="true">
  <svg viewBox="0 0 1440 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#F2F2F0"/>
        <stop offset="100%" stop-color="#FAFAF8"/>
      </linearGradient>
      <linearGradient id="mountain1" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#E8E8E3"/>
        <stop offset="100%" stop-color="#F2F2F0"/>
      </linearGradient>
    </defs>
    
    <!-- Background -->
    <rect width="1440" height="600" fill="url(#sky)"/>
    
    <!-- Distant mountains -->
    <path d="M0,400 Q200,280 400,350 Q600,250 800,320 Q1000,260 1200,340 Q1350,300 1440,320 L1440,600 L0,600 Z" fill="url(#mountain1)" opacity="0.5"/>
    
    <!-- Mid mountains -->
    <path d="M0,450 Q300,350 600,420 Q900,360 1200,430 Q1350,400 1440,420 L1440,600 L0,600 Z" fill="#EAEAE5" opacity="0.3"/>
    
    <!-- Subtle geometric accents -->
    <circle cx="1100" cy="150" r="80" fill="#2B4C7E" opacity="0.03"/>
    <circle cx="300" cy="200" r="60" fill="#2B4C7E" opacity="0.02"/>
    
    <!-- Horizontal accent line -->
    <line x1="0" y1="380" x2="1440" y2="380" stroke="#E5E5E0" stroke-width="1" opacity="0.5"/>
  </svg>
</div>

<style>
  .novel-scene {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  
  .novel-scene svg {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
