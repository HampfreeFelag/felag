---
// NordicScene.astro — фоновый слой скандинавского ландшафта
// Располагается строго позади контента (z-index: 1)
// Пропускает клики сквозь себя (pointer-events: none)
---
<div class="nordic-scene-wrapper">
  <!-- Фоновый SVG с горами/туманом -->
  <div class="nordic-scene" aria-hidden="true">
    <svg class="nordic-bg-svg" viewBox="0 0 1920 600" preserveAspectRatio="xMidYMid slice">
      <path d="M0,600 L400,300 L800,600 Z" fill="var(--nordic-deep-blue-light)" opacity="0.15" />
      <path d="M600,600 L1000,200 L1400,600 Z" fill="var(--nordic-deep-blue)" opacity="0.1" />
      <path d="M1200,600 L1600,350 L1920,600 Z" fill="var(--nordic-amber)" opacity="0.05" />
    </svg>
  </div>
  <!-- Контент поверх фона -->
  <div class="nordic-content">
    <slot />
  </div>
</div>

<style>
  .nordic-scene-wrapper {
    position: relative;
    width: 100%;
    min-height: 400px;
    overflow: hidden;
  }

  .nordic-scene {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1; /* Строго позади контента */
    pointer-events: none; /* Пропускает клики сквозь себя */
    overflow: hidden;
  }

  .nordic-bg-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .nordic-content {
    position: relative;
    z-index: 2; /* Поверх фона */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 400px;
    padding: 4rem 2rem;
  }
</style>
