---
export interface Props {
  name?: string;
  size?: number;
  color?: string;
}

const { name = 'default', size = 24, color = 'currentColor' } = Astro.props;
---

<svg 
  width={size} 
  height={size} 
  viewBox="0 0 24 24" 
  fill="none" 
  stroke={color} 
  stroke-width="2" 
  stroke-linecap="round" 
  stroke-linejoin="round"
  aria-hidden="true"
>
  <!-- Простая векторная руна/символ (например, альфа или простая геометрия) -->
  <path d="M12 2 L2 22 L22 22 Z" />
  <path d="M12 6 L12 18" />
</svg>