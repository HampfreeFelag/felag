---
/*
  ═══════════════════════════════════════════════════════════════
  RELATED POSTS COMPONENT (Topic Clusters)
  ═══════════════════════════════════════════════════════════════
*/

import { getRelatedPosts } from '../utils/blog';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import Banner from './Banner.astro';

interface Props {
	currentPostId: string;
	category?: string;
	limit?: number;
}

const { currentPostId, category, limit = 3 } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// КРИТИЧНО: Передаём язык для фильтрации постов только текущего языка
const langCode = lang as 'ru' | 'en';
const relatedPosts = await getRelatedPosts(currentPostId, category, limit, langCode);

const baseUrl = import.meta.env.BASE_URL.endsWith('/') 
	? import.meta.env.BASE_URL 
	: import.meta.env.BASE_URL + '/';

// Related header translations
const relatedHeader = {
	ru: '[ ПОХОЖИЕ МАТЕРИАЛЫ ]',
	en: '[ RELATED MATERIALS ]'
}[lang] || '[ RELATED_DATA ]';

const readMoreText = {
	ru: 'Читать полностью',
	en: 'Read more'
}[lang] || 'Читать полностью';
---

{relatedPosts.length > 0 && (
	<section class="related-posts" aria-labelledby="related-posts-title">
		<div class="related-posts-grid">
			{relatedPosts.map((post) => {
				// We stay within the same language for related posts
				return (
					<a 
						href={`${baseUrl}${lang}/library/${post.id}/`} 
						class="related-post-card"
						aria-label={`${readMoreText}: ${post.data.title}`}
					>
						<Banner 
							title={post.data.title} 
							subtitle={post.data.description}
							category={(post.data as any).category} 
							type="preview" 
						/>
						<div class="related-post-meta">
							{('category' in post.data && (post.data as any).category) && (
								<span class="related-post-category">[{t(`cat.${(post.data as any).category}` as any) || (post.data as any).category.toUpperCase()}]</span>
							)}
						</div>
					</a>
				);
			})}
		</div>
	</section>
)}

<style>
	.related-posts {
		/* Не добавляем лишних отступов — контейнер статьи уже управляет spacing */
		margin: 0;
		padding: 0;
	}

	.related-posts-title {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.875rem;
		color: var(--color-accent);
		text-transform: uppercase;
		letter-spacing: 1px;
		margin-bottom: 1.5rem;
		font-weight: 700;
	}

	.related-posts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: var(--space-3); /* 24px — кратно 8 */
		align-items: start; /* НЕ растягиваем карточки по высоте */
		min-width: 0; /* Сетка не выталкивает контейнер за границы */
	}

	.related-post-card {
		display: block;
		align-self: start; /* не тянем до высоты ряда */
		height: auto;
		min-width: 0; /* Карточка не выталкивает сетку за границы блока */
		padding: var(--space-3); /* 24px — кратно 8 */
		border: var(--border-structural);
		border-bottom: 4px solid var(--color-border);
		background: var(--nes-bg-secondary);
		text-decoration: none;
		color: inherit;
		/* 8-bit hover как у .post-card */
		transition: border-bottom-color 0.10s steps(3),
		            color 0.10s steps(3);
	}

	/* Hover унифицирован с остальными карточками (без кича/transform) */
	.related-post-card:hover {
		border-bottom-color: var(--nes-accent-yellow);
		/* Глобальный a:hover добавляет underline — запрещаем в карточках */
		text-decoration: none !important;
	}

	/* На всякий случай запрещаем подчёркивание вложенного текста */
	.related-post-card:hover * {
		text-decoration: none !important;
	}

	.related-post-card:hover .banner-title {
		color: var(--nes-accent-yellow);
	}

	.related-post-title {
		font-size: 1.125rem;
		font-weight: 700;
		margin-bottom: 0.75rem;
		color: var(--color-text);
		line-height: 1.4;
	}

	.related-post-description {
		font-size: 0.875rem;
		color: var(--color-text-secondary);
		line-height: 1.6;
		margin-bottom: 1rem;
	}

	.related-post-meta {
		display: flex;
		align-items: center;
		gap: var(--space-1); /* 8px — кратно 8 */
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.75rem;
		margin-top: var(--space-2); /* 16px — кратно 8 */
	}

	.related-post-category {
		color: var(--color-accent);
		font-weight: 700;
	}

	@media (max-width: 768px) {
		.related-posts-grid {
			grid-template-columns: 1fr;
		}

		.related-post-card {
			padding: var(--space-3); /* 24px — кратно 8 */
		}
	}
</style>
