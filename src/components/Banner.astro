---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
	title: string;
	subtitle?: string;
	category?: string;
	type?: 'preview' | 'full';
	className?: string;
}

const { 
	title, 
	subtitle = '', 
	category = 'general', 
	type = 'preview',
	className = '' 
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const cleanSubtitle = subtitle?.endsWith('.') ? subtitle.slice(0, -1) : subtitle;

const rawCat = category || 'general';
const catKey = rawCat.toLowerCase().trim();
const rubric = t(`cat.${catKey}` as any) || rawCat;

// Category color class
const catClass = category === 'crypto' ? 'cat-crypto' :
                 category === 'technical-analysis' ? 'cat-technical' :
                 category === 'algo-trading' ? 'cat-algo' :
                 category === 'fundamental-analysis' ? 'cat-fundamental' : '';
---

<div class={`banner banner--${type} ${className}`}>
	<div class="banner-inner">
		<div class="banner-top">
			{title && <h2 class="banner-title">{title}</h2>}
			{cleanSubtitle && <p class="banner-subtitle">{cleanSubtitle}</p>}
		</div>
		<div class="banner-bottom">
			{rubric && <span class={`banner-rubric ${catClass}`}>{rubric}</span>}
			<span class="banner-watermark">FÉLAG</span>
		</div>
	</div>
</div>
