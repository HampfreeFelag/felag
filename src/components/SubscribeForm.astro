---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
	withContainer?: boolean;
	title?: string;
}

const { withContainer = true, title } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const formTitle = title || t('home.newsletter_title');
---

<div class={`subscribe-section ${withContainer ? 'subscribe-with-container' : ''}`}>
	{withContainer && <h2>{formTitle}</h2>}
	<p class="newsletter-desc">{t('home.newsletter_desc')}</p>
	
	<form id="newsletter-form-component" class="subscribe-form">
		<input 
			type="email" 
			placeholder={t('home.newsletter_placeholder')} 
			required 
			name="email"
		/>
		<button type="submit" class="btn-submit">
			{t('home.newsletter_button')}
		</button>
		<p id="form-error-comp" class="error-text" style="display: none; color: var(--color-error) !important; margin-top: var(--space-sm);">
			{t('home.newsletter_error')}
		</p>
		<p id="form-success-comp" class="success-text" style="display: none; color: var(--color-success) !important; margin-top: var(--space-sm);">
			{t('home.newsletter_success')}
		</p>
	</form>
</div>

	<script is:inline define:vars={{ sendingMsg: t('home.newsletter_sending'), buttonMsg: t('home.newsletter_button') }}>
		function initForm() {
			const form = document.getElementById('newsletter-form-component');
			if (!form) return;

			const errorMsg = document.getElementById('form-error-comp');
			const successMsg = document.getElementById('form-success-comp');
			const submitBtn = form.querySelector('.btn-submit');

			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				if (errorMsg) errorMsg.style.display = 'none';
				if (successMsg) successMsg.style.display = 'none';
				
				const email = form.email.value;
				const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

				if (!emailPattern.test(email)) {
					if (errorMsg) errorMsg.style.display = 'block';
					return;
				}

				if (submitBtn) {
					submitBtn.disabled = true;
					submitBtn.dataset.originalText = submitBtn.innerText;
					submitBtn.innerText = sendingMsg;
				}

				setTimeout(() => {
					if (successMsg) successMsg.style.display = 'block';
					form.reset();
					if (submitBtn) {
						submitBtn.disabled = false;
						submitBtn.innerText = buttonMsg;
					}
				}, 1000);
			});
		}

		initForm();
		document.addEventListener('astro:page-load', initForm);
	</script>
