---
// Компактный реферальный баннер (адаптивный, 8-bit стиль)
// Переиспользуемый компонент для вставки в статьи
// Стиль как у Banner.astro: рамка категории с box-shadow

import type { AdBanner } from '../config/ad-banners';

export interface Props {
  banner: AdBanner;
  lang?: 'ru' | 'en';
  className?: string;
  slug?: string; // Для UTM-меток
}

const { banner, lang = 'ru', className = '', slug = 'unknown' } = Astro.props;

// Build UTM-tagged link
const utmSource = 'marketlab-blog';
const utmMedium = 'referral-banner';
const utmCampaign = banner.id;
const utmContent = slug;
const utmTerm = banner.categories?.[0] || 'general';

const utmParams = `?utm_source=${utmSource}&utm_medium=${utmMedium}&utm_campaign=${utmCampaign}&utm_content=${utmContent}&utm_term=${utmTerm}`;
const finalLink = banner.link.startsWith('/')
  ? banner.link.replace('{lang}', lang)
  : banner.link.includes('?')
    ? `${banner.link}&utm_source=${utmSource}&utm_medium=${utmMedium}&utm_campaign=${utmCampaign}&utm_content=${utmContent}&utm_term=${utmTerm}`
    : `${banner.link}${utmParams}`;
---

<div class={`ad-banner-container ${className}`}>
  <a
    href={finalLink}
    target="_blank"
    rel="nofollow sponsored"
    class="ad-banner-link"
    data-banner-id={banner.id}
    data-banner-name={banner.title.replace(/"/g, '&quot;')}
    data-banner-link={finalLink}
    style={{
      '--bg-start': banner.colors.bgStart,
      '--bg-end': banner.colors.bgEnd,
      '--text-color': banner.colors.text,
      '--cta-bg': banner.colors.ctaBg,
      '--cta-text': banner.colors.ctaText,
      '--border-color': banner.colors.border,
    }}
    onclick="trackBannerClick(this)"
  >
    <div class="ad-banner-content">
      <div class="text-block">
        <div class="title">{banner.title}</div>
        <div class="subtitle">{banner.subtitle}</div>
      </div>
      <div class="cta">
        {banner.cta.replace('→', '')}
        <span class="cta-arrow"></span>
      </div>
    </div>
  </a>
</div>

<script>
  // Track banner clicks (GA4) - global function
  if (typeof window !== 'undefined') {
    window.trackBannerClick = function(element) {
      if (typeof gtag === 'undefined') return;
      
      const bannerId = element.dataset.bannerId || 'unknown';
      const bannerName = element.dataset.bannerName || 'Unknown';
      const bannerLink = element.dataset.bannerLink || '';
      const category = document.querySelector('article')?.dataset.category || '';
      const lang = document.querySelector('html')?.lang || 'ru';
      const pathname = window.location.pathname;
      
      // Send event to GA4
      gtag('event', 'referral_banner_click', {
        event_category: 'referral',
        event_label: bannerName,
        banner_id: bannerId,
        banner_link: bannerLink,
        article_category: category,
        article_lang: lang,
        article_path: pathname,
        transport_type: 'beacon',
      });
      
      // Also track as outbound link
      gtag('event', 'click', {
        event_category: 'outbound',
        event_label: bannerLink,
        transport_type: 'beacon',
      });
    };
  }
</script>

<style>
  .ad-banner-container {
    width: 100%;
    max-width: var(--max-width-post, 800px);
    margin: 2rem auto;
    padding: 0;
    display: block;
    box-sizing: border-box;
  }

  .ad-banner-link {
    display: block;
    background: linear-gradient(135deg, var(--bg-start), var(--bg-end));
    border-radius: 0;
    padding: 20px 24px;
    text-decoration: none !important;
    position: relative;
    overflow: hidden;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }

  /* Scanlines effect (как в Banner.astro) */
  .ad-banner-link::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(
      rgba(0, 0, 0, 0.05),
      rgba(0, 0, 0, 0.05) 1px,
      transparent 1px,
      transparent 4px
    );
    pointer-events: none;
    z-index: 1;
  }

  /* Border frame (как рамка категории в Banner.astro) */
  .ad-banner-link::after {
    content: "";
    position: absolute;
    top: 6px;
    left: 6px;
    right: 6px;
    bottom: 6px;
    border: 2px solid var(--border-color);
    border-radius: 0;
    pointer-events: none;
    z-index: 1;
  }

  .ad-banner-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    width: 100%;
  }

  .text-block {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
    overflow: visible;
    min-width: 0;
  }

  .title {
    font-family: 'Press Start 2P', monospace;
    font-size: clamp(12px, 2vw + 10px, 16px);
    color: var(--text-color);
    line-height: 1.4;
    text-transform: uppercase;
    white-space: normal;
    overflow: visible;
    text-overflow: clip;
    margin: 0;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .subtitle {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(10px, 1.5vw + 8px, 12px);
    color: var(--text-color);
    opacity: 0.9;
    line-height: 1.5;
    white-space: normal;
    overflow: visible;
    text-overflow: clip;
    margin: 0;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Press Start 2P', monospace;
    font-size: clamp(10px, 1.5vw + 8px, 12px);
    background: var(--cta-bg);
    color: var(--cta-text);
    padding: 8px 16px;
    border: 2px solid #000;
    box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.3);
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
    margin: 0;
  }

  .cta-arrow {
    display: inline-block;
    width: 0;
    height: 0;
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-left: 7px solid currentColor;
    line-height: 0;
    vertical-align: middle;
  }

  /* Mobile: центровка и перенос кнопки */
  @media (max-width: 768px) {
    .ad-banner-container {
      margin: 2rem auto;
      padding: 0;
    }

    .ad-banner-content {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 12px;
    }

    .text-block {
      width: 100%;
      text-align: center;
    }

    .cta {
      white-space: nowrap;
      width: auto;
      min-width: 200px;
      max-width: 300px;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .ad-banner-container {
      padding: 0;
    }

    .ad-banner-link {
      padding: 16px 18px;
    }

    .title {
      font-size: 11px;
    }

    .subtitle {
      font-size: 9px;
    }

    .cta {
      padding: 7px 16px;
      min-width: 180px;
    }
  }

  @media (max-width: 360px) {
    .ad-banner-container {
      padding: 0;
    }

    .ad-banner-link {
      padding: 14px 16px;
    }

    .title {
      font-size: 10px;
    }

    .subtitle {
      font-size: 8px;
    }

    .cta {
      font-size: 8px;
      padding: 6px 14px;
      min-width: 160px;
    }
  }
</style>
