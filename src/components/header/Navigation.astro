---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const currentPath = Astro.url.pathname;
const isLibrary = currentPath.includes('/library');
const isAbout = currentPath.includes('/about');
---

<nav class="desktop-nav" aria-label={t('nav.aria_label')}>
	<a href={translatePath('library')} class:list={['nav-link', { active: isLibrary }]} aria-current={isLibrary ? 'page' : undefined}>{t('nav.library')}</a>
	<a href={translatePath('about')} class:list={['nav-link', { active: isAbout }]} aria-current={isAbout ? 'page' : undefined}>{t('nav.about')}</a>
</nav>
